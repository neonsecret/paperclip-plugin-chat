{
  "name": "chat-ui",
  "id": "@paperclipai/plugin-chat-ui",
  "displayName": "Chat",
  "description": "Interactive AI copilot for managing tasks, agents, and workspaces through natural conversation",
  "version": "0.1.0",
  "apiVersion": 1,
  "categories": ["ui"],
  "icon": "MessageCircle",
  "capabilities": [
    "ui.page.register",
    "ui.sidebar.register",
    "issues.read",
    "issues.create",
    "issues.update",
    "issue.comments.create",
    "agents.read",
    "projects.read",
    "activity.read",
    "costs.read"
  ],
  "nav": {
    "section": "plugins",
    "label": "Chat",
    "path": "/plugins/chat-ui"
  },
  "ui": {
    "slots": [
      {
        "type": "page",
        "id": "chat-page",
        "displayName": "Chat",
        "exportName": "default"
      },
      {
        "type": "sidebar",
        "id": "chat-sidebar",
        "displayName": "Chat",
        "exportName": "default"
      }
    ]
  }
}
